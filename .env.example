# Copia este archivo a .env y ajusta los valores reales.

# En desarrollo, apunta al backend corriendo localmente.
# En producción, apunta al dominio real de la API.
# El portal agrega automáticamente /api/v1; no lo repitas aquí.
VITE_API_URL=http://localhost:8000

# Opcional. Endpoint propio para recibir FCP, LCP, CLS e INP mediante sendBeacon.
# Si queda vacío, las métricas se miden en el navegador sin enviarse a terceros.
VITE_WEB_VITALS_ENDPOINT=
